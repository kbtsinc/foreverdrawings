{
  "name": "Forever Drawings",
  "short_name": "Drawings",
  "description": "Your child's art vault — preserve every drawing forever",
  "start_url": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#FFF8F0",
  "theme_color": "#E8640A",
  "categories": ["lifestyle", "photo"],
  "lang": "en-US",

  "icons": [
    {
      "src": "/icons/icon-72.png",
      "sizes": "72x72",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-96.png",
      "sizes": "96x96",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-128.png",
      "sizes": "128x128",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-144.png",
      "sizes": "144x144",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-152.png",
      "sizes": "152x152",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icons/icon-384.png",
      "sizes": "384x384",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],

  "screenshots": [
    {
      "src": "/screenshots/gallery.png",
      "sizes": "390x844",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Gallery view of your child's artwork"
    }
  ],

  "shortcuts": [
    {
      "name": "Upload Artwork",
      "short_name": "Upload",
      "description": "Quickly add a new artwork photo",
      "url": "/?action=upload",
      "icons": [{ "src": "/icons/shortcut-upload.png", "sizes": "96x96" }]
    },
    {
      "name": "View Gallery",
      "short_name": "Gallery",
      "description": "Browse all saved artwork",
      "url": "/",
      "icons": [{ "src": "/icons/shortcut-gallery.png", "sizes": "96x96" }]
    }
  ],

  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "artwork",
          "accept": ["image/jpeg", "image/png", "image/heic", "image/webp", "image/*"]
        }
      ]
    }
  },

  "file_handlers": [
    {
      "action": "/open-file",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".heic", ".webp"]
      }
    }
  ],

  "protocol_handlers": [
    {
      "protocol": "web+masterpiece",
      "url": "/?share=%s"
    }
  ]
}
